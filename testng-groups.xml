<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    GROUP EXECUTION SUITE
    =====================
    Purpose  : Run a specific group of tests without touching testng.xml (full regression)
               or testng-parallel.xml (parallel execution).

    Usage:
      All groups (regression) : mvn clean test -DsuiteXmlFile=testng-groups.xml
      Smoke only              : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=smoke
      Sanity only             : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=sanity
      Critical only           : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=critical
      Negative only           : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=negative
      E2E only                : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=e2e
      API only                : mvn clean test -DsuiteXmlFile=testng-groups.xml -Dgroups=api

    Group hierarchy:
      regression  → all 38 TCs
      sanity      → happy paths across all modules
      smoke       → one TC per module, fastest subset
      critical    → login + cart + checkout (business-critical)
      negative    → all error/validation/boundary paths
      e2e         → cross-module user journey tests
      api         → REST Assured tests only, no browser required
-->

<suite name="TutorialsNinja - Group Suite" verbose="1">

    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.RetryListener"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="tests.registration"/>
            <package name="tests.login"/>
            <package name="tests.search"/>
            <package name="tests.product"/>
            <package name="tests.wishlist"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
            <package name="tests.compare"/>
            <package name="tests.api"/>
        </packages>
    </test>

    <test name="Sanity Tests">
        <groups>
            <run>
                <include name="sanity"/>
            </run>
        </groups>
        <packages>
            <package name="tests.registration"/>
            <package name="tests.login"/>
            <package name="tests.search"/>
            <package name="tests.product"/>
            <package name="tests.wishlist"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
            <package name="tests.compare"/>
            <package name="tests.api"/>
        </packages>
    </test>

    <test name="Critical Tests">
        <groups>
            <run>
                <include name="critical"/>
            </run>
        </groups>
        <packages>
            <package name="tests.login"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
        </packages>
    </test>

    <test name="Negative Tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <packages>
            <package name="tests.registration"/>
            <package name="tests.login"/>
            <package name="tests.search"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
        </packages>
    </test>

    <test name="E2E Tests">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <packages>
            <package name="tests.wishlist"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
        </packages>
    </test>

    <test name="API Tests">
        <groups>
            <run>
                <include name="api"/>
            </run>
        </groups>
        <packages>
            <package name="tests.api"/>
        </packages>
    </test>

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="tests.registration"/>
            <package name="tests.login"/>
            <package name="tests.search"/>
            <package name="tests.product"/>
            <package name="tests.wishlist"/>
            <package name="tests.cart"/>
            <package name="tests.checkout"/>
            <package name="tests.compare"/>
            <package name="tests.api"/>
        </packages>
    </test>

</suite>